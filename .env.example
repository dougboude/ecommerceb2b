# Copy this file to .env and fill in values for your environment.
# .env is gitignored and must never be committed.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev default — matches the Docker container managed by start.sh
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerceb2b

# Postgres data directory — must be on the WSL2/Linux native filesystem.
# Do NOT point this at /mnt/c/... (Windows filesystem lacks chmod support).
PGDATA_DIR=$HOME/.local/share/ecommerceb2b/pgdata

# ── Embedding sidecar ─────────────────────────────────────────────────────────
EMBEDDING_SERVICE_URL=http://127.0.0.1:8002
EMBEDDING_SERVICE_TOKEN=dev-token-change-me

# ── SSE relay ─────────────────────────────────────────────────────────────────
SSE_HOST=127.0.0.1
SSE_PORT=8001
SSE_SERVICE_URL=http://127.0.0.1:8001
SSE_SERVICE_TOKEN=dev-token-change-me
SSE_STREAM_SECRET=dev-stream-secret

# ── Django dev server ─────────────────────────────────────────────────────────
DJANGO_ADDR=127.0.0.1:8000

# ── Session/Auth security ─────────────────────────────────────────────────────
# Inactivity timeout (seconds). 1800 = 30 minutes.
SESSION_COOKIE_AGE=1800
# Sliding timeout: each authenticated request extends session age.
SESSION_SAVE_EVERY_REQUEST=true
# If true, browser close ends session regardless of age.
SESSION_EXPIRE_AT_BROWSER_CLOSE=false

# Failed login lockout controls
LOGIN_FAILED_ATTEMPTS_LIMIT=5
LOGIN_FAILED_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900

# ── Email (console backend for local dev — no real mail sent) ─────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
